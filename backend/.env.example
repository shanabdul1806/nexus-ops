# ─── AI Provider (at least one required) ─────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-6
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# ─── Jenkins ─────────────────────────────────────────────────────────────────
JENKINS_URL=http://your-jenkins.example.com:8080
JENKINS_USER=admin
JENKINS_TOKEN=your_jenkins_api_token

# ─── Kibana / Elasticsearch ──────────────────────────────────────────────────
KIBANA_URL=http://your-kibana.example.com:5601
KIBANA_USER=elastic
KIBANA_PASSWORD=your_kibana_password
KIBANA_INDEX=logs-*

# ─── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repository

# ─── Portainer ───────────────────────────────────────────────────────────────
PORTAINER_URL=http://your-portainer.example.com:9000
PORTAINER_TOKEN=your_portainer_api_token
# 0 = auto-discover the first online endpoint; set to a specific ID to pin it
PORTAINER_ENDPOINT=0

# ─── Prometheus ───────────────────────────────────────────────────────────────
# When running via docker-compose, Prometheus is on the internal network at:
PROMETHEUS_URL=http://prometheus:9090
# Uncomment and set if your Prometheus instance requires basic auth:
# PROMETHEUS_USER=admin
# PROMETHEUS_PASSWORD=your_prometheus_password

# ─── Grafana ─────────────────────────────────────────────────────────────────
# Browser-accessible URL — used for both backend API calls AND dashboard iframe embeds.
# • Local docker-compose: leave this commented out; the compose file defaults the
#   backend to http://grafana:3000 (internal network) and the browser to
#   http://localhost:3001 (mapped port) automatically.
# • External / production Grafana: set to the public URL, e.g.:
# GRAFANA_URL=https://grafana.your-company.com
# Service account token (Grafana UI → Administration → Service Accounts → Add token):
GRAFANA_TOKEN=your_grafana_service_account_token
# Admin credentials (used by docker-compose to set the initial admin password):
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_in_production

# ─── Collaboration ────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://your-extension-id
DASHBOARD_URL=http://localhost:3000
DB_PATH=./data/nexus.db

# ─── AWS ─────────────────────────────────────────────────────────────────────
# IAM user or role credentials with read access to EC2, ECS, Lambda,
# CloudWatch, CloudWatch Logs, and Cost Explorer.
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
# AWS_SESSION_TOKEN=  # only needed for temporary credentials / SSO

# ─── GCP ─────────────────────────────────────────────────────────────────────
# Service account with roles:
#   Compute Viewer, Container Viewer, Cloud Run Viewer,
#   Monitoring Viewer, Logs Viewer
GCP_PROJECT_ID=your-gcp-project-id
GCP_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private_key from the JSON key file (newlines as \n):
GCP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# Alternatively, mount a key file and set:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/keyfile.json

# ─── Azure ───────────────────────────────────────────────────────────────────
# App registration (service principal) with Reader role on the subscription
# and Log Analytics Reader on any Log Analytics workspaces.
# Create via: az ad sp create-for-rbac --role Reader --scopes /subscriptions/{id}
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-app-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id
# Optional — needed only for /azure/logs queries:
# AZURE_LOG_ANALYTICS_WORKSPACE_ID=your-workspace-guid
