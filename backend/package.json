{
  "name": "nexus-ops-backend",
  "version": "1.0.0",
  "description": "AI-powered Nexus Ops backend service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "axios": "^1.6.0",
    "openai": "^4.20.0",
    "@anthropic-ai/sdk": "^0.20.0",
    "drizzle-orm": "^0.39.0",
    "postgres": "^3.4.4",
    "node-schedule": "^2.1.1",
    "ws": "^8.16.0",
    "uuid": "^9.0.0",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "prom-client": "^15.1.0",
    "@aws-sdk/client-ec2": "^3.758.0",
    "@aws-sdk/client-ecs": "^3.758.0",
    "@aws-sdk/client-lambda": "^3.758.0",
    "@aws-sdk/client-cloudwatch": "^3.758.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.758.0",
    "@aws-sdk/client-cost-explorer": "^3.758.0",
    "googleapis": "^144.0.0",
    "@azure/identity": "^4.4.1",
    "@azure/arm-compute": "^21.5.0",
    "@azure/arm-containerservice": "^20.0.0",
    "@azure/monitor-query": "^1.3.1",
    "@azure/arm-costmanagement": "^1.0.0-beta.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/node-schedule": "^2.1.6",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.0",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.3.0",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "supertest": "^6.3.4",
    "axios-mock-adapter": "^1.22.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "moduleNameMapper": {
      "@shared/(.*)": "<rootDir>/../shared/$1"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
    },
    "collectCoverageFrom": [
      "src/connectors/**/*.ts",
      "src/routes/**/*.ts",
      "!src/**/*.d.ts"
    ]
  }
}
